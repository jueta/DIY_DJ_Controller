        <!-- Potentiometers (CC 10-24) -->

            <!-- Pot 0 (CC 10) - Deck 1 Gain -->
            <control>
                <group>[Channel1]</group>
                <key>pregain</key>
                <status>0xB0</status>
                <midino>0x0A</midino>
                <options>
                    <invert/>
                </options>
            </control>

            <!-- Pot 1 (CC 11) - Deck 2 Gain -->
            <control>
                <group>[Channel2]</group>
                <key>pregain</key>
                <status>0xB0</status>
                <midino>0x0B</midino>
                <options>
                    <invert/>
                </options>
            </control>

            <!-- Pot 2 (CC 12) - Deck 1 High EQ -->
            <control>
                <group>[EqualizerRack1_[Channel1]_Effect1]</group>
                <key>parameter3</key>
                <status>0xB0</status>
                <midino>0x0C</midino>
                <options>
                    <invert/>
                </options>
            </control>

            <!-- Pot 3 (CC 13) - Deck 2 High EQ -->
            <control>
                <group>[EqualizerRack1_[Channel2]_Effect1]</group>
                <key>parameter3</key>
                <status>0xB0</status>
                <midino>0x0D</midino>
                <options>
                    <invert/>
                </options>
            </control>

            <!-- Pot 4 (CC 14) - Deck 1 Mid EQ -->
            <control>
                <group>[EqualizerRack1_[Channel1]_Effect1]</group>
                <key>parameter2</key>
                <status>0xB0</status>
