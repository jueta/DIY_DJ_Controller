            <!-- Button 10: Deck 2 Function Button 1 (Note 70) -->
            <control>
                <group>[Channel2]</group>
                <key>hotcue_1_activate</key>
                <status>0x90</status>
                <midino>0x46</midino>
                <options>
                    <normal/>
                </options>
