            <!-- Pot 11 (CC 21) - Deck 2 Tempo Fader -->
            <control>
                <group>[Channel2]</group>
                <key>rate</key>
                <status>0xB0</status>
                <midino>0x15</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Pot 12 (CC 22) - Deck 1 Master -->
            <control>
                <group>[Channel1]</group>
                <key>volume</key>
                <status>0xB0</status>
                <midino>0x16</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Pot 13 (CC 23) - Mixer Crossfader -->
            <control>
                <group>[Master]</group>
                <key>crossfader</key>
                <status>0xB0</status>
                <midino>0x17</midino>
                <options>
                    <invert/>
                </options>
            </control>

            <!-- Pot 14 (CC 24) - Deck 1 Tempo Fader -->
            <control>
                <group>[Channel1]</group>
                <key>rate</key>
                <status>0xB0</status>
                <midino>0x18</midino>
                <options>
