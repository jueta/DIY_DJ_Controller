            <!-- Physical button for Deck 1 load -->
            <control>
                <group>[Channel1]</group>
                <key>LoadSelectedTrack</key>
                <status>0x90</status>
                <midino>0x4E</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button A2: Load Music to Deck 2 (Note 77 from firmware) -->
            <control>
                <group>[Channel2]</group>
                <key>LoadSelectedTrack</key>
                <status>0x90</status>
                <midino>0x4D</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Physical button for enter/expand folder -->
            <control>
                <group>[Playlist]</group>
                <key>ToggleSelectedSidebarItem</key>
                <status>0x90</status>
                <midino>0x4C</midino>
                <options>
