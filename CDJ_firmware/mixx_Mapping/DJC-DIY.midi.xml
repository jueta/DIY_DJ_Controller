<?xml version='1.0' encoding='utf-8'?>
<MixxxControllerPreset schemaVersion="1" mixxxVersion="">
    <info>
        <name>DJC-DIY</name>
    </info>
    <controller id="">
        <scriptfiles>
            <file functionprefix="DJCDIY" filename="DJC-DIY-scripts.js"/>
        </scriptfiles>
        <controls>

        <!-- Deck 1 Controls -->

            <!-- Jog Wheel 2 (CC 27 - actually Jog Wheel 1) -->
            <control>
                <group>[Channel1]</group>
                <key>DJCDIY.wheelTurn</key>
                <status>0xB0</status>
                <midino>0x1B</midino>
                <options>
                    <script-binding/>
                </options>
            </control>

            <!-- Button 1: Deck 1 Loop In (Note 61) -->
            <control>
                <group>[Channel1]</group>
                <key>loop_in</key>
                <status>0x90</status>
                <midino>0x3D</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button 0: Deck 1 Loop Out (Note 60) -->
            <control>
                <group>[Channel1]</group>
                <key>loop_out</key>
                <status>0x90</status>
                <midino>0x3C</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button 7: Deck 1 Play/Pause (Note 67) -->
            <control>
                <group>[Channel1]</group>
                <key>play</key>
                <status>0x90</status>
                <midino>0x43</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button 6: Deck 1 Cue (Note 66) -->
            <control>
                <group>[Channel1]</group>
                <key>cue_default</key>
                <status>0x90</status>
                <midino>0x42</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button 4: Deck 1 Function Button 1 (Note 64) -->
            <control>
                <group>[Channel1]</group>
                <key>hotcue_1_activate</key>
                <status>0x90</status>
                <midino>0x40</midino>
                <options>
                    <normal/>
                </options>
            </control>

            <!-- Button 5: Deck 1 Function Button 2 (Note 65) -->
            <control>
                <group>[Channel1]</group>
                <key>hotcue_2_activate</key>
